{
  "sourceLanguage": "en",
  "strings": {
    "Steady reads your blood pressure, blood glucose, weight, heart rate and blood oxygen from Health to show them in one place. Your data never leaves your devices.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Steady 会从“健康”读取你的血压、血糖、体重、心率和血氧，并集中显示在一个地方。你的数据不会离开你的设备。"
          }
        }
      }
    },
    "Steady saves readings you log by hand into Health, so all your health apps stay in sync.": {
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Steady 会把你手动记录的读数保存到“健康”，让你的健康数据保持同步。"
          }
        }
      }
    }
  },
  "version": "1.3"
}
